<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Background of the splash screen -->
        <item name="windowSplashScreenBackground">#4B502A</item>
        <item name="android:windowBackground">@drawable/splash_gradient_bg</item>

        <!-- The icon in the middle -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>

        <!-- Use the main app theme after splash -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
