<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Unified Logo + Gradient Background (Guaranteed Visibility) -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_unified</item>
        <item name="windowSplashScreenBackground">#4B502A</item> <!-- Matches the gradient edge -->
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>

        <!-- Post-splash theme -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
