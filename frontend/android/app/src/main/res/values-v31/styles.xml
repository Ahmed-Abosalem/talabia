<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Using the Pre-baked Single Asset (Card + Logo) to guarantee visual accuracy on Android 12+ -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_final</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_final</item>

        <item name="windowSplashScreenBackground">#4B502A</item>
        <item name="android:windowSplashScreenBackground">#4B502A</item>

        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>

        <!-- Post-splash theme -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
