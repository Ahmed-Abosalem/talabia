<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Removed redundant background layer (handled by windowSplashScreenBackground) -->

    <!-- 1. Logo Card (Rounded Square Square with Soft Edges) -->
    <item
        android:width="200dp"
        android:height="200dp"
        android:gravity="center"
        android:drawable="@drawable/splash_logo_card" />

    <!-- 2. The New Logo (Centered on the Card - Following the 45% Safe Zone Rule) -->
    <item
        android:width="90dp"
        android:height="90dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/splash_logo"
            android:gravity="center" />
    </item>
</layer-list>
