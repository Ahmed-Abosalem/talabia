<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The Aura Glow Layer -->
    <background>
        <inset android:inset="0dp">
            <shape android:shape="rectangle">
                <gradient
                    android:type="radial"
                    android:gradientRadius="450dp"
                    android:startColor="#F1F5E1"
                    android:endColor="#4B502A"
                    android:centerX="0.5"
                    android:centerY="0.5" />
            </shape>
        </inset>
    </background>
    <!-- The Logo Layer -->
    <foreground>
        <inset
            android:inset="30%">
            <bitmap
                android:src="@drawable/splash_logo"
                android:gravity="center" />
        </inset>
    </foreground>
</adaptive-icon>
