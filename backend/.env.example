# =====================================
# Talabia Backend - Production Example
# =====================================

# Runtime
NODE_ENV=production
PORT=5000

# Database (MongoDB)
MONGO_URI=

# Auth / Security
JWT_SECRET=

# CORS (comma-separated list)
# مثال: https://talabia.com,https://www.talabia.com
ALLOWED_ORIGINS=

# Email (SMTP) - optional إذا عندك إرسال بريد
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Cloudinary - optional إذا تستخدمه لرفع الصور
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: Base URL for backend (useful for links/emails)
# مثال: https://api.talabia.com
BASE_URL=
