# ========================================================
# 🚀 Talabia Backend - Production Configuration Template
# ========================================================
# Copy this file to .env on your VPS and fill in the values.
# IMPORTANT: Never commit your actual .env file to Git!

# --- 1. Environment ---
NODE_ENV=production
PORT=5000

# --- 2. Database (MongoDB Atlas) ---
# Replace with your actual connection string from MongoDB Atlas
# Example: mongodb+srv://username:password@cluster.mongodb.net/talabia
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.talabia.mongodb.net/talabia

# --- 3. Authentication & Security ---
# Use a long, random string (e.g., generated via: openssl rand -base64 32)
JWT_SECRET=YOUR_STRONG_PRODUCTION_SECRET_KEY_HERE

# --- 4. CORS & Networking ---
# Comma-separated list of allowed domains
# Must include your domain: https://www.talabia.net
ALLOWED_ORIGINS=https://www.talabia.net,https://talabia.net

# --- 5. Base URL (Images/API) ---
# The public URL of your backend server
BASE_URL=https://talabia.net

# --- 6. Email (SMTP) - Optional ---
# Required for password resets and order notifications
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# --- 7. Cloudinary - Optional ---
# Only if you migrate from local storage to Cloudinary later
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
